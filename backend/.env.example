# --- CORS --------------------------------------------------------------------
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://indies-99li.vercel.app

# --- MiniMax LLM -------------------------------------------------------------
# API key issued from the MiniMax developer console.
MINIMAX_API_KEY=your-minimax-api-key
# Base URL of the MiniMax API. Override only if you use a regional endpoint.
MINIMAX_BASE_URL=https://api.minimax.io/v1
# Planner/API-routing model used to produce structured tool calls.
MINIMAX_MODEL=MiniMax-Text-01
# Optional user-facing conversational model. Leave empty to reuse MINIMAX_MODEL.
MINIMAX_CHAT_MODEL=MiniMax-Text-01

# --- Mercado Publico (Chilean government procurement API) --------------------
# Ticket (token) issued by https://api.mercadopublico.cl
MERCADO_PUBLICO_TICKET=your-mercado-publico-ticket
# Base URL for the public v1 services of Mercado Publico.
MERCADO_PUBLICO_BASE_URL=https://api.mercadopublico.cl/servicios/v1/publico

# --- Auth (Clerk) ------------------------------------------------------------
# JWKS URL for verifying Clerk session JWTs.
# Find it in your Clerk dashboard → API Keys → Advanced → JWKS URL.
# Format: https://<your-clerk-domain>/.well-known/jwks.json
# Leave empty to disable auth (all requests treated as anonymous).
# Production: https://real-firefly-25.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=

# --- Persistence -------------------------------------------------------------
# Async SQLAlchemy URL used for conversations, messages, LLM traces and tool runs.
# Local development can use SQLite. Production/serverless deployments must use
# PostgreSQL because Vercel does not provide a persistent filesystem for SQLite.
# Production format: postgresql+asyncpg://<user>:<password>@<host>/<dbname>
DATABASE_URL=sqlite+aiosqlite:///./data/indies.db
# Optional PostgreSQL/Neon URL used by Contraloria and Camara tools. Leave empty
# for local development if you only need the app, docs, health, Mercado Publico,
# and Senado-backed flows.
CONTRALORIA_DATABASE_URL=
